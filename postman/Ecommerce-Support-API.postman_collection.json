{
  "info": {
    "_postman_id": "32a92e5c-909a-4ce3-8431-bb4f14db8241",
    "name": "Ecommerce Support API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the FastAPI-based e-commerce support multi-agent backend."
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        },
        "description": "Confirms that the API server is running."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Health status is ok', function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData.status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Upload File",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "{{uploadFilePath}}"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/upload",
          "host": ["{{baseUrl}}"],
          "path": ["api", "upload"]
        },
        "description": "Uploads a document or image. Set `uploadFilePath` in the environment before running."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Upload returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "pm.collectionVariables.set('lastFileId', jsonData.file_id);",
              "pm.collectionVariables.set('lastFilename', jsonData.filename);",
              "",
              "pm.test('Upload returns file metadata', function () {",
              "  pm.expect(jsonData.file_id).to.be.a('string');",
              "  pm.expect(jsonData.filename).to.be.a('string');",
              "  pm.expect(jsonData.chunks_indexed).to.be.a('number');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Query Without Upload",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"Why was my refund rejected?\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/query",
          "host": ["{{baseUrl}}"],
          "path": ["api", "query"]
        },
        "description": "Queries the support system without explicitly passing uploaded file IDs."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Query returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Query returns answer and references fields', function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData.answer).to.be.a('string');",
              "  pm.expect(jsonData.references).to.be.an('array');",
              "  pm.expect(jsonData.confidence).to.be.a('string');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Query Using Uploaded File",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"I uploaded my invoice. Am I eligible for a refund?\",\n  \"file_ids\": [\"{{lastFileId}}\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/query",
          "host": ["{{baseUrl}}"],
          "path": ["api", "query"]
        },
        "description": "Run `Upload File` first. This request uses the saved `lastFileId` from the upload response."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Uploaded-file query returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Uploaded-file query returns grounded response shape', function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData.answer).to.be.a('string');",
              "  pm.expect(jsonData.reasoning_summary).to.be.a('string');",
              "  pm.expect(jsonData.references).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "lastFileId",
      "value": ""
    },
    {
      "key": "lastFilename",
      "value": ""
    }
  ]
}
